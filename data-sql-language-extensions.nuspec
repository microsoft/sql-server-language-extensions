<?xml version="1.0"?>
<package >
    <metadata minClientVersion="2.5">
        <id>data-sql-language-extensions</id>
        <version>1.0</version>
        <authors>extclrcommitters</authors>
        <owners>extclrcommitters</owners>
        <description>SQL Language Extensions</description>
    </metadata>
    <files>
        <!-- The current path is "build\out" for artifacts, with two builds (linux, windows) it choses the first artifact downloaded. Use full paths -->

        <!-- Copy build files, such as dlls and symbols, to the build\languagename\debug or release folder -->
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Windows-Official-master\drop\outputs\build\out\**\debug\**\*.*" target="build" />
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Windows-Official-master\drop\outputs\build\out\**\release\**\*.*" target="build" />
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Linux-Official-master\drop\outputs\build\out\**\debug\**\*.*" target="build" />
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Linux-Official-master\drop\outputs\build\out\**\release\**\*.*" target="build" />

        <!-- Copy extension zips from package pipeline artifacts to the build\languagename\debug or release folder -->
        <!-- Windows packages-->
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Windows-Official-master\drop\outputs\package\out\dotnetcore-C#-extension\packages\debug\dotnetcore-C#-lang-extension.zip" target="build\dotnetcore-C#-extension\debug" />
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Windows-Official-master\drop\outputs\package\out\dotnetcore-C#-extension\packages\release\dotnetcore-C#-lang-extension.zip" target="build\dotnetcore-C#-extension\release" />
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Windows-Official-master\drop\outputs\package\out\java-extension\packages\debug\java-lang-extension.zip" target="build\java-extension\debug" />
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Windows-Official-master\drop\outputs\package\out\java-extension\packages\release\java-lang-extension.zip" target="build\java-extension\release" />
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Windows-Official-master\drop\outputs\package\out\pythonextension\packages\debug\python-lang-extension.zip" target="build\pythonextension\debug" />
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Windows-Official-master\drop\outputs\package\out\pythonextension\packages\release\python-lang-extension.zip" target="build\pythonextension\release" />
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Windows-Official-master\drop\outputs\package\out\RExtension\packages\debug\R-lang-extension.zip" target="build\RExtension\debug" />
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Windows-Official-master\drop\outputs\package\out\RExtension\packages\release\R-lang-extension.zip" target="build\RExtension\release" />

        <!-- Linux packages-->
        <!-- Copy extension zips from package pipeline artifacts to the build\languagename\debug or release folder -->
        <!-- Java extension is not shipped from this repo, it is shipped from mssql-server. To avoid confusion, do not
             include it with this nuget package -->
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Linux-Official-master\drop\outputs\package\out\pythonextension\packages\debug\python-lang-extension-linux.zip" target="build\pythonextension\debug" />
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Linux-Official-master\drop\outputs\package\out\pythonextension\packages\release\python-lang-extension-linux.zip" target="build\pythonextension\release" />
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Linux-Official-master\drop\outputs\package\out\RExtension\packages\debug\R-lang-extension-linux.zip" target="build\RExtension\debug" />
        <file src="..\..\..\..\..\_Data-SQL-Language-Extensions-Linux-Official-master\drop\outputs\package\out\RExtension\packages\release\R-lang-extension-linux.zip" target="build\RExtension\release" />
    </files>
</package>