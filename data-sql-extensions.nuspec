<?xml version="1.0"?>
<package >
    <metadata minClientVersion="2.5">
        <id>data-sql-extensions</id>
        <version>1.0</version>
        <authors>brnieb</authors>
        <owners>brnieb</owners>
        <description>SQL Language Extensions</description>
    </metadata>
    <files>
        <file src=".\**\**\debug\**\*.*" target="build" />
        <file src=".\**\**\release\**\*.*" target="build" />
        <file src=".\java-extension\packages\debug\java-lang-extension.zip" target="build\debug" />
        <file src=".\java-extension\packages\release\java-lang-extension.zip" target="build\release" />
        <file src=".\pythonextension\packages\debug\python-lang-extension.zip" target="build\debug" />
        <file src=".\pythonextension\packages\release\python-lang-extension.zip" target="build\release" />
        <file src=".\RExtension\packages\debug\R-lang-extension.zip" target="build\debug" />
        <file src=".\RExtension\packages\release\R-lang-extension.zip" target="build\release" />
    </files>
</package>